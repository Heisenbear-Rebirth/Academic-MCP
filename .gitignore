# Python virtual environments & Cache
venv/
.venv/
.venv*/
env/
.cam_test/
__pycache__/
*.pyc
*.pyo
*.pyd

# Testing & Auto-Generated Document Outputs
# Our scrapers dynamically download PDFs and Markdown to output folders, do not track them!
test_md_output*/
test_output_*/
test_outputs/
arxiv_test_md_output/
ieee_test_md_output/
downloads/
downloads_test/
scratch/
scratch_test_downloads/
scratch_*.py
tmp/
.codex_tmp/
.uv-cache/

# Playwright & DataDome Authenticated Persistent Context profiles
# DO NOT track these to avoid breaking local cross-environment security states
.sd_profile/
.acm_profile/
.gs_profile/
.ieee_profile/
.cnki_profile/
.cnki_storage_state.json
.dawei_profile/
.patyee_profile/
.test_profile*/
# Ephemeral per-PID profile copies created by pooled_profile when a canonical
# profile is held by another live MCP server. Auto-deleted on close(); ignored
# in case a crash leaves one behind.
.*_profile__p*/
# Dedicated profile sets created via MCP_PROFILE_SUFFIX, e.g. .sd_profile_codex/
.*_profile_*/
.playwright-mcp/
.ms-playwright/

# Debug and Logging
*.log
*.err
*.out
test_*_logs.txt
test_prefs.pdf
sd_debug_*.png

# Local settings / IDE
.vscode/
.idea/
.claude/
.DS_Store

# Local library (MySQL + file repo)
.env
.repo/
