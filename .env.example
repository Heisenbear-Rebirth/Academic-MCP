# Copy to .env and fill in your local MongoDB connection.
# The .env file lives in the project root and is gitignored.
#
# Either provide a full connection URI (recommended, supports auth / replica
# sets / options)...
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=academic_mcp
#
# ...or leave MONGODB_URI unset and let it be assembled from these parts:
# MONGODB_HOST=127.0.0.1
# MONGODB_PORT=27017
# MONGODB_USER=
# MONGODB_PASSWORD=
